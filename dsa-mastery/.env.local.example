# Copy to .env.local and fill in.
# .env.local is gitignored; never commit real keys.

# Supabase — create a project at https://supabase.com (free tier), then find these in
# Project Settings → API. Anon key is safe for browser use when RLS is enabled.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ntfy.sh topic for push notifications. Install the ntfy app on your phone and
# subscribe to this exact topic to receive pushes.
VITE_NTFY_TOPIC=dsa-pradeep-5cfeb00911af7618
